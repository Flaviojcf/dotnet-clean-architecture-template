{
#if (useKafka)
  "KafkaSettings": {
    "BootstrapServers": "kafka:29092",
    "GroupId": "company-sample-service-consumer-group",
    "ConsumerTimeoutMs": 100,
    "Topics": {
      "SampleEvent": "sample-event"
    }
  },
#endif
#if (useSerilog)
  "Serilog": {
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  }
#else
  "Worker": {
    "Name": "company-sample-service"
  }
#endif
}
