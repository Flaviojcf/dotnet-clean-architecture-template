{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
#if (useKafka)
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "company-sample-service-consumer-group",
    "ConsumerTimeoutMs": 100,
    "Topics": {
      "SampleEvent": "sample-event"
    }
  },
#endif
#if (useSerilog)
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  }
#else
  "Worker": {
    "Name": "company-sample-service"
  }
#endif
}
