{
  "CampaignApi": {
    "BaseUrl": "https://localhost:55903/",
    "TimeoutSeconds": 10,
    "Retry": {
      "Attempts": 3,
      "BaseDelayMilliseconds": 200
    }
  },
#if (useAuth)
  "Jwt": {
    "Authority": "",
    "Audience": "",
    "RequireHttpsMetadata": true
  },
#endif
#if (useOpenTelemetry)
  "Observability": {
    "ServiceName": "Company.SampleService.WebApi"
  },
#endif
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
