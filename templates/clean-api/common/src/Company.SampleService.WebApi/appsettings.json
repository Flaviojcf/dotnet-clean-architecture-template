{
#if (useSqlServer || usePostgreSql)
  "ConnectionStrings": {
#if (useSqlServer)
    "SqlServer": "Server=localhost,1433;Database=sample_service;User Id=sa;Password=Your_password123;TrustServerCertificate=True;"
#endif
#if (useSqlServer && usePostgreSql)
    ,
#endif
#if (usePostgreSql)
    "PostgreSql": "Host=localhost;Port=5432;Database=sample_service;Username=postgres;Password=postgres"
#endif
  },
#endif
#if (useMongoDB)
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "sample_service"
  },
#endif
#if (useKafka)
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "TopicName": "item-created"
  },
#endif
#if (useAuth)
  "JwtSettings": {
    "SecretKey": "super-secret-key-used-for-template-only-1234567890",
    "Issuer": "Company.SampleService",
    "Audience": "Company.SampleService.Client",
    "AccessTokenExpirationMinutes": 60
  },
#endif
#if (useOpenTelemetry)
  "Observability": {
    "ServiceName": "Company.SampleService"
  }
#else
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
#endif
}
