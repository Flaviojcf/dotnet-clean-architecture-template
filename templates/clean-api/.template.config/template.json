{
  "$schema": "http://json.schemastore.org/template",
  "author": "Flaviojcf",
  "classifications": [
    "Web",
    "API",
    "ASP.NET Core",
    "Clean Architecture"
  ],
  "identity": "Flaviojcf.CleanArchitecture.ModularApi",
  "name": "Modular Clean Architecture API",
  "shortName": "cleanarchapi",
  "sourceName": "Company.SampleService",
  "preferNameDirectory": true,
  "placeholderFilename": "-.-",
  "symbols": {
    "useSqlServer": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include SQL Server persistence infrastructure (EF Core).",
      "defaultValue": "true"
    },
    "usePostgreSql": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include PostgreSQL persistence infrastructure (EF Core).",
      "defaultValue": "false"
    },
    "useMongoDB": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include MongoDB persistence infrastructure (MongoDB.Driver).",
      "defaultValue": "false"
    },
    "useKafka": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include Kafka messaging infrastructure (Confluent.Kafka).",
      "defaultValue": "false"
    },
    "useMediatR": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Use MediatR for CQRS dispatch. When false, use cases are injected directly into controllers.",
      "defaultValue": "true"
    },
    "useFluentValidation": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include FluentValidation for request validation.",
      "defaultValue": "true"
    },
    "useSerilog": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include Serilog for structured logging.",
      "defaultValue": "true"
    },
    "useOpenTelemetry": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include OpenTelemetry for distributed tracing and metrics.",
      "defaultValue": "true"
    },
    "useSwagger": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include Swagger/OpenAPI documentation (Swashbuckle + API versioning).",
      "defaultValue": "true"
    },
    "useAuth": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include JWT authentication infrastructure (BCrypt, JwtBearer).",
      "defaultValue": "true"
    }
  },
  "sources": [
    {
      "source": "./common",
      "target": "./",
      "modifiers": [
        {
          "condition": "(!useAuth)",
          "exclude": [
            "src/Company.SampleService.Infrastructure.Auth/**",
            "src/Company.SampleService.Application/Abstractions/Authentication/**",
            "src/Company.SampleService.Application/Settings/JwtSettings.cs"
          ]
        }
      ]
    },
    {
      "source": "./providers/sqlserver",
      "target": "./",
      "condition": "(useSqlServer)"
    },
    {
      "source": "./providers/postgresql",
      "target": "./",
      "condition": "(usePostgreSql)"
    },
    {
      "source": "./providers/mongodb",
      "target": "./",
      "condition": "(useMongoDB)"
    },
    {
      "source": "./messaging/kafka",
      "target": "./",
      "condition": "(useKafka)"
    }
  ],
  "specialCustomOperations": {
    "**/*.csproj": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    },
    "**/*.props": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    },
    "**/*.yml": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    },
    "**/*.json": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    },
    "**/*.slnx": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    }
  },
  "primaryOutputs": [
    {
      "path": "Company.SampleService.slnx"
    },
    {
      "path": "src/Company.SampleService.WebApi/Company.SampleService.WebApi.csproj"
    }
  ]
}
